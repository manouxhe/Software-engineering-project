<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KitBox.ViewModels"
             x:Class="KitBox.Views.SummaryPage"
             x:DataType="vm:SummaryViewModel"
             Background="White">

    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Spacing="20">
        <TextBlock Text="Order summary" FontSize="28" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>

        <TextBlock Text="{Binding FinalCabinet.Lockers.Count, StringFormat='Your cabinet contains {0} lockers.'}" Foreground="Gray" FontSize="18"/>

        <StackPanel Orientation="Horizontal" Spacing = "12" HorizontalAlignment="Center">
            <Button Content= "Add to cart"
                    Command="{Binding AddToCartCommand}"
                    Classes="primary"
                    Padding="15"
                    HorizontalAlignment = "Center"/>
        </StackPanel>
        <Button Content="Back to customization"
                Command="{Binding GoBackCommand}"
                Classes="secondary"
                HorizontalAlignment="Center" Padding="15"/>
    </StackPanel>

</UserControl>