<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KitBox.ViewModels"
             x:Class="KitBox.Views.ManagerDashboardPage"
             x:DataType="vm:ManagerDashboardViewModel">

  <StackPanel Spacing="12" Margin="24">
    <TextBlock Text="Espace Manager" FontSize="22" Foreground="Black" FontWeight="Bold"/>
    <Button Content="Retour Accueil" Command="{Binding GoHomeCommand}" Width="140" Background= "#2196F3"/>
  </StackPanel>
</UserControl>