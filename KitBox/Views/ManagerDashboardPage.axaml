<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KitBox.ViewModels"
             xmlns:v="clr-namespace:KitBox.Views"
             x:Class="KitBox.Views.ManagerDashboardPage"
             x:DataType="vm:ManagerDashboardViewModel">

    <Grid RowDefinitions="Auto, *" Margin="24">

        <StackPanel Grid.Row="0" Orientation="Horizontal" Spacing="20" Margin="0,0,0,20" VerticalAlignment="Center">
            <TextBlock Text="Manager Space" FontSize="22" Foreground="Black" FontWeight="Bold" VerticalAlignment="Center"/>
            <Button Content="Back to home" Command="{Binding GoHomeCommand}" Width="140" Classes="primary"/>
        </StackPanel>

        <TabControl Grid.Row="1">

            <TabItem Header="Stock &amp; Restocking">
                <Border Background="#F9F9F9" CornerRadius="8" Padding="20" Margin="0,10,0,0">
                    <TextBlock Text="Ici ce sera l'espace pour voir toute la liste des composants et pouvoir commander (StockOrder)."
                               FontSize="18" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Border>
            </TabItem>

            <TabItem Header="Customer Orders">
                <v:ManagerOrdersView DataContext="{Binding OrdersTab}" />
            </TabItem>

            <TabItem Header="Manager Orders">
                <Border Background="#F9F9F9" CornerRadius="8" Padding="20" Margin="0,10,0,0">
                    <TextBlock Text="Ici ce sera l'espace pour voir les commandes de réapprovisionnement effectuées par le manager."
                               FontSize="18" Foreground="#555" HorizontalAlignment="Center" VerticalAlignment="Center" TextWrapping="Wrap"/>
                </Border>
            </TabItem>

            <TabItem Header="Suppliers Info">
                <ScrollViewer Margin="0,15,0,0">
                    <ItemsControl ItemsSource="{Binding Suppliers}">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15" BoxShadow="0 2 5 0 #20000000">
                                    <Grid ColumnDefinitions="Auto, *">

                                        <TextBlock Grid.Column="0" Text="🏢" FontSize="40" VerticalAlignment="Center" Margin="0,0,20,0"/>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" Spacing="5">

                                            <TextBlock Text="{Binding Name}" FontSize="20" FontWeight="Bold" Foreground="Black"/>
                                            <TextBlock Text="{Binding SubName}" FontSize="16" FontStyle="Italic" Foreground="#666"/>

                                            <Border Background="#E0E0E0" Height="1" Margin="0,5,0,5" HorizontalAlignment="Stretch"/>

                                            <StackPanel Orientation="Horizontal" Spacing="8">
                                                <TextBlock Text="📍" FontSize="16" VerticalAlignment="Center"/>
                                                <StackPanel>
                                                    <TextBlock Text="{Binding Address}" FontSize="16" Foreground="#333"/>
                                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                                        <TextBlock Text="{Binding PostalCode}" FontSize="16" Foreground="#333" FontWeight="SemiBold"/>
                                                        <TextBlock Text="{Binding City}" FontSize="16" Foreground="#333" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </StackPanel>
                                            </StackPanel>

                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </TabItem>

        </TabControl>
    </Grid>
</UserControl>