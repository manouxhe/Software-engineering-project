<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KitBox.ViewModels"
             x:Class="KitBox.Views.ManagerStockOrdersView"
             x:DataType="vm:ManagerStockOrdersViewModel">

    <ScrollViewer Margin="0,10,0,0">
        <ItemsControl ItemsSource="{Binding StockOrders}">
            <ItemsControl.ItemTemplate>
                <DataTemplate>
                    <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12" BoxShadow="0 2 5 0 #20000000">
                        <Grid ColumnDefinitions="Auto, *, Auto, Auto, Auto">

                            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,20,0">
                                <TextBlock Text="Date :" Foreground="#888" FontSize="12"/>
                                <TextBlock Text="{Binding Date, StringFormat='d'}" FontWeight="Bold" FontSize="14" Foreground="Black"/>
                            </StackPanel>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="Part &amp; Supplier :" Foreground="#888" FontSize="12"/>
                                <TextBlock Text="{Binding PartCode, StringFormat='Pièce : {0}'}" FontWeight="Bold" FontSize="16" Foreground="Black"/>
                                <TextBlock Text="{Binding SupplierName}" Foreground="#555" FontSize="14"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2" VerticalAlignment="Center" Margin="15,0">
                                <TextBlock Text="Quantity :" Foreground="#888" FontSize="12"/>
                                <TextBlock Text="{Binding Quantity}" FontWeight="Bold" FontSize="18" Foreground="#2196F3"/>
                            </StackPanel>

                            <StackPanel Grid.Column="3" VerticalAlignment="Center" Margin="15,0" Width="100">
                                <TextBlock Text="Status :" Foreground="#888" FontSize="12"/>
                                <TextBlock Text="{Binding Status}" FontWeight="Bold" FontSize="16" Foreground="{Binding StatusColor}"/>
                            </StackPanel>

                            <Button Grid.Column="4" Content="Validate" Background="#4CAF50" Foreground="White" FontWeight="Bold" VerticalAlignment="Center"
                                    IsVisible="{Binding IsInProgress}"
                                    Command="{Binding $parent[UserControl].DataContext.ValidateStockOrderCommand}"
                                    CommandParameter="{Binding}"/>

                        </Grid>
                    </Border>
                </DataTemplate>
            </ItemsControl.ItemTemplate>
        </ItemsControl>
    </ScrollViewer>
</UserControl>