<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="using:KitBox.ViewModels"
             x:Class="KitBox.Views.FinalizePage"
             x:DataType="vm:FinalizeViewModel"
             Background="White">

  <ScrollViewer>
    <StackPanel Margin="30" Spacing="14">
      <TextBlock Text="Checkout" FontSize="28" FontWeight="Bold"/>
      <TextBlock Text="{Binding Items.Count, StringFormat='Your cart contains {0} cabinet(s).'}"/>

      <Border Background="#F4F4F4" Padding="12" CornerRadius="8">
        <ItemsControl ItemsSource="{Binding Items}">
          <ItemsControl.ItemTemplate>
            <DataTemplate>
              <StackPanel Margin="0,0,0,8">
                <TextBlock Text="{Binding CartNumber, StringFormat='Cabinet n°{0}'}" FontWeight="Bold" />
                <TextBlock Text="{Binding Width, StringFormat='Width : {0}'}"/>
                <TextBlock Text="{Binding Depth, StringFormat='Depth : {0}'}"/>
                <TextBlock Text="{Binding Lockers.Count, StringFormat='Lockers : {0}'}"/>
              </StackPanel>
            </DataTemplate>
          </ItemsControl.ItemTemplate>
        </ItemsControl>
      </Border>

      <TextBlock Text="{Binding TotalPrice, StringFormat='Total price : {0} €'}" FontSize="18" FontWeight="SemiBold" Foreground="Black"/>
      <TextBlock Text="{Binding PaymentMessage}" TextWrapping="Wrap" Foreground="Black"/>

      <ItemsControl ItemsSource="{Binding InfoMessages}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding .}" Foreground="#8A6D3B" TextWrapping="Wrap"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <ItemsControl ItemsSource="{Binding StockAlerts}" IsVisible="{Binding HasStockIssue}">
        <ItemsControl.ItemTemplate>
          <DataTemplate>
            <TextBlock Text="{Binding .}" Foreground="#CC0000" TextWrapping="Wrap"/>
          </DataTemplate>
        </ItemsControl.ItemTemplate>
      </ItemsControl>

      <TextBox Watermark="Your email adress"
               Text="{Binding EmailAddress}"
               IsVisible="{Binding HasStockIssue}"/>

      <StackPanel Orientation="Horizontal" Spacing="12">
        <Button Content="Complete order / Pay"
                Command="{Binding PayCommand}"
                Classes="primary"
                Padding="12"/>
        <Button Content="Back to home"
                Command="{Binding GoHomeCommand}"
                Classes="secondary"
                Padding="12"/>
      </StackPanel>
    </StackPanel>
  </ScrollViewer>
</UserControl>
