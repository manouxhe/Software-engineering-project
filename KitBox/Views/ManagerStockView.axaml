<UserControl xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:vm="clr-namespace:KitBox.ViewModels"
             x:Class="KitBox.Views.ManagerStockView"
             x:DataType="vm:ManagerStockViewModel">

    <Grid>
        <Grid Margin="0,15,0,0">
            <ScrollViewer>
                <ItemsControl ItemsSource="{Binding Parts}">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,12" BoxShadow="0 2 5 0 #20000000">
                                <Grid ColumnDefinitions="150, *, 100, 100, Auto">

                                    <StackPanel Grid.Column="0" VerticalAlignment="Center">
                                        <TextBlock Text="Reference :" Foreground="#888" FontSize="12"/>
                                        <TextBlock Text="{Binding Code}" FontWeight="Bold" FontSize="16" Foreground="Black"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="10,0">
                                        <TextBlock Text="Kind / Dimensions :" Foreground="#888" FontSize="12"/>
                                        <TextBlock Text="{Binding Kind}" FontWeight="SemiBold" FontSize="16" Foreground="#333"/>
                                        <TextBlock Text="{Binding Dimensions}" Foreground="#666" FontSize="14" TextWrapping="Wrap"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="2" VerticalAlignment="Center">
                                        <TextBlock Text="Min Stock :" Foreground="#888" FontSize="12"/>
                                        <TextBlock Text="{Binding MinStock}" FontWeight="SemiBold" FontSize="16" Foreground="#333"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="3" VerticalAlignment="Center">
                                        <TextBlock Text="In stock :" Foreground="#888" FontSize="12"/>
                                        <TextBlock Text="{Binding Stock}" FontWeight="Bold" FontSize="18" Foreground="{Binding StockColor}"/>
                                    </StackPanel>

                                    <StackPanel Grid.Column="4" VerticalAlignment="Center" Spacing="8" Width="130">
                                        <Border Background="#FFF0F0" BorderBrush="#FF5252" BorderThickness="1" CornerRadius="6" Padding="5" IsVisible="{Binding IsLowStock}">
                                            <TextBlock Text="⚠️ Low Stock" Foreground="#FF5252" FontWeight="Bold" HorizontalAlignment="Center"/>
                                        </Border>

                                        <Button Content="Order"
                                                Classes="primary"
                                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Center"
                                                Command="{Binding $parent[UserControl].DataContext.OpenOrderPopupCommand}"
                                                CommandParameter="{Binding}"/>
                                    </StackPanel>

                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>
        </Grid>

        <Grid ZIndex="100" Background="#80000000" IsVisible="{Binding IsPopupOpen}">
            <Border Background="White" CornerRadius="12" Padding="30" VerticalAlignment="Center" HorizontalAlignment="Center" Width="450" BoxShadow="0 10 30 0 #40000000">
                <StackPanel Spacing="20">
                    <TextBlock Text="{Binding SelectedPart.Code, StringFormat='Order : {0}'}" FontSize="22" FontWeight="Bold" Foreground="Black" HorizontalAlignment="Center"/>

                    <StackPanel>
                        <TextBlock Text="Supplier and Offer" FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,5"/>
                        <ComboBox ItemsSource="{Binding AvailableOffers}" SelectedItem="{Binding SelectedOffer}" HorizontalAlignment="Stretch" PlaceholderText="Sélectionner un fournisseur...">
                            <ComboBox.ItemTemplate>
                                <DataTemplate>
                                    <StackPanel Orientation="Horizontal" Spacing="5">
                                        <TextBlock Text="{Binding SupplierName}" FontWeight="Bold"/>
                                        <TextBlock Text="-"/>
                                        <TextBlock Text="{Binding PurchasePrice, StringFormat='{}{0} €'}"/>
                                        <TextBlock Text="{Binding DeliveryDelay, StringFormat='(Délai : {0} j)'}" Foreground="Gray"/>
                                    </StackPanel>
                                </DataTemplate>
                            </ComboBox.ItemTemplate>
                        </ComboBox>
                    </StackPanel>

                    <StackPanel>
                        <TextBlock Text="Quantity to order" FontWeight="SemiBold" Foreground="Black" Margin="0,0,0,5"/>
                        <NumericUpDown Value="{Binding OrderQuantity}" Minimum="1" Maximum="5000" FormatString="0"/>
                    </StackPanel>

                    <Border Background="#F5F5F5" Padding="15" CornerRadius="8">
                        <Grid ColumnDefinitions="*, Auto">
                            <TextBlock Grid.Column="0" Text="Total price estimated :" FontSize="18" FontWeight="SemiBold" Foreground="Black" VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1" Text="{Binding TotalPrice, StringFormat='{}{0:0.00} €'}" FontSize="18" FontWeight="Bold" Foreground="#2196F3" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="10" Margin="0,10,0,0">
                        <Button Content="Cancel" Command="{Binding ClosePopupCommand}" Classes="secondary"/>
                        <Button Content="Confirm the order" Command="{Binding ValidateOrderCommand}" Background="#4CAF50" Foreground="White" FontWeight="Bold"/>
                    </StackPanel>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>