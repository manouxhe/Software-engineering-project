<!-- File: Views/MainWindow.axaml -->
<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:KitBox.ViewModels"
        x:Class="KitBox.Views.MainWindow"
        x:DataType="vm:MainViewModel"
        x:Name="RootWindow"
        Title="KitBox Manager"
        Background="#E7E7E7">

  <Grid RowDefinitions="Auto,*">

    <!-- BARRE DU HAUT -->
    <Border Grid.Row="0" Background="#2196F3" Padding="6">
      <DockPanel LastChildFill="True">
        <TextBlock Text="KitBox" FontSize="18" FontWeight="Bold" VerticalAlignment="Center"/>

        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center" HorizontalAlignment="Right">
          <Border Background="#2196F3" CornerRadius="999" Padding="6,2">
            <TextBlock Text="{Binding CartItems.Count}" Foreground="White" FontWeight="Bold"/>
          </Border>

          <Button Command="{Binding ToggleCartCommand}" Padding="10,6">
            <TextBlock Text="🛒" FontSize="18"/>
          </Button>
        </StackPanel>
      </DockPanel>
    </Border>

    <!-- CONTENU NORMAL (tes pages) -->
    <ContentControl Grid.Row="1" Content="{Binding CurrentPage}" />

    <!-- FOND SOMBRE CLIQUABLE POUR FERMER -->
    <Button Grid.RowSpan="2"
            IsVisible="{Binding CartOpen}"
            Command="{Binding CloseCartCommand}"
            Background="#66000000"
            HorizontalAlignment="Stretch"
            VerticalAlignment="Stretch"
            Content="{x:Null}"/>

    <!-- PANNEAU PANIER (droite, ~1/3 fenêtre) -->
    <Border Grid.RowSpan="2"
            IsVisible="{Binding CartOpen}"
            HorizontalAlignment="Right"
            VerticalAlignment="Stretch"
            Width="360"
            Background="#F5F5F5"
            BorderBrush="#D0D0D0"
            BorderThickness="1"
            CornerRadius="12,0,0,12"
            Padding="14">

      <Grid RowDefinitions="Auto,*,Auto" RowSpacing="10">
        <TextBlock Text="Votre panier" Foreground ="#000000" Grid.Row="0" FontSize="20" FontWeight="Bold" HorizontalAlignment="Left"/>

        <ScrollViewer Grid.Row="1">
          <ItemsControl ItemsSource="{Binding CartItems}">
            <ItemsControl.ItemTemplate>
              <DataTemplate>
                <Border Background="#828488" CornerRadius="10" Padding="12" Margin="0,0,0,10">
                  <Grid ColumnDefinitions="*,Auto" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10">
                    <TextBlock Grid.Row="0" Grid.Column="0" Text="{Binding Width, StringFormat='Largeur: {0}'}"/>
                    <Button Grid.Row="0" Grid.Column="1"
                            Content="X"
                            Background="#2196F3"
                            Command="{Binding #RootWindow.DataContext.RemoveFromCartCommand}"
                            CommandParameter="{Binding}"
                            Padding="8,2"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="{Binding Depth, StringFormat='Profondeur: {0}'}"/>
                    <TextBlock Grid.Row="2" Grid.Column="0" Text="{Binding Lockers.Count, StringFormat='Casiers: {0}'}"/>
                  </Grid>
                </Border>
              </DataTemplate>
            </ItemsControl.ItemTemplate>
          </ItemsControl>
        </ScrollViewer>

        <Button Grid.Row="2"
                Content="Finaliser"
                Command="{Binding FinalizeCommand}"
                Classes="primary"
                Padding="16,10"
                HorizontalAlignment = "Center"
                VerticalAlignment = "Center"
                Width = "160"/>
    
      </Grid>

    </Border>

  </Grid>
</Window>